{
  "name": "sonarqube-api-client",
  "version": "0.0.1",
  "description": "Community SonarQube Web API client for JavaScript!",
  "private": true,
  "type": "module",
  "license": "MIT",
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rimraf dist && rollup -c",
    "lint": "eslint --cache --fix .",
    "lint:check": "eslint --cache .",
    "format": "prettier --cache --write --ignore-unknown .",
    "format:check": "prettier --cache --check --ignore-unknown .",
    "test": "jest --coverage",
    "release": "npx semantic-release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "p-limit": "^6.2.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.0",
    "rollup-plugin-copy": "^3.5.0",
    "semantic-release": "^25.0.5",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "keywords": [
    "sonar",
    "sonarqube",
    "api",
    "client"
  ],
  "bugs": {
    "url": "https://github.com/ciqol/sonarqube-api-client/issues"
  },
  "homepage": "https://github.com/ciqol/sonarqube-api-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ciqol/sonarqube-api-client.git"
  }
}
